@{
    Layout = "_Layout";
    ViewBag.Titulo = "Reservas Ativas";
}

@model List<ListarReservasViewModel>;

<a class="btn btn-outline-primary rounded-pill px-4 mb-3" asp-action="Cadastrar">Cadastrar Nova Reserva</a>

@if (Model.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-2 rounded-3" role="alert">
        Nenhuma reserva ativa.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover table-bordered align-middle bg-white">
            <thead class="table-primary">
                <tr>
                    <th>ID</th>
                    <th>Amigo</th>
                    <th>Revista</th>
                    <th>Data da Reserva</th>
                    <th>Status</th>
                    <th>Ações</th>
                </tr>
            </thead>

            <tbody>
                @foreach (ListarReservasViewModel r in Model)
                {
                    <tr>
                        <td>@r.Id</td>
                        <td>@r.NomeAmigo</td>
                        <td>@r.TituloRevista</td>
                        <td>@r.DataReserva.ToString("dd/MM/yyyy")</td>
                        <td>@r.Status</td>
                        <td>
                            <div class="d-flex gap-2">
                                <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Converter"
                                   asp-route-id="@r.Id">
                                    Converter em Empréstimo
                                </a>

                                <a class="btn btn-outline-danger btn-sm rounded-pill px-3" asp-action="Cancelar"
                                   asp-route-id="@r.Id">
                                    Cancelar
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
