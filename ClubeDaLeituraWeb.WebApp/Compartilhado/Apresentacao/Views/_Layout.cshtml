<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Titulo - Clube da Leitura</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --paper: #f7f1e3;
            --paper-light: #fffaf0;
            --ink: #253229;
            --muted: #7a6f61;
            --green-900: #193326;
            --green-800: #214734;
            --green-700: #2e6249;
            --wine: #7a2735;
            --wine-dark: #5c1c28;
            --gold: #c69c4a;
            --gold-soft: #f2dfb5;
            --border: rgba(37, 50, 41, .12);
            --shadow: 0 24px 70px rgba(25, 51, 38, .13);
            --radius-xl: 28px;
            --radius-lg: 20px;
            --radius-md: 14px;
        }

        * {
            text-rendering: optimizeLegibility;
        }

        body {
            min-height: 100vh;
            color: var(--ink);
            background:
                radial-gradient(circle at 8% 8%, rgba(198, 156, 74, .20), transparent 28rem),
                radial-gradient(circle at 90% 12%, rgba(122, 39, 53, .12), transparent 26rem),
                linear-gradient(135deg, #fbf7ec 0%, #f3ead7 48%, #efe2c6 100%);
            font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            opacity: .28;
            background-image:
                linear-gradient(rgba(25, 51, 38, .035) 1px, transparent 1px),
                linear-gradient(90deg, rgba(25, 51, 38, .035) 1px, transparent 1px);
            background-size: 34px 34px;
            mask-image: linear-gradient(to bottom, black, transparent 90%);
            z-index: -1;
        }

        .app-navbar {
            position: sticky;
            top: 0;
            z-index: 1040;
            border-bottom: 1px solid rgba(37, 50, 41, .10);
            background: rgba(255, 250, 240, .82);
            backdrop-filter: blur(18px);
        }

        .navbar-inner {
            min-height: 74px;
        }

        .brand-mark {
            width: 44px;
            height: 44px;
            border-radius: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: var(--paper-light);
            background:
                linear-gradient(145deg, var(--green-900), var(--green-700));
            box-shadow: 0 14px 34px rgba(25, 51, 38, .22);
        }

        .navbar-brand {
            color: var(--green-900);
            letter-spacing: -.04em;
        }

        .brand-subtitle {
            color: var(--muted);
            font-size: .76rem;
            letter-spacing: .08em;
            text-transform: uppercase;
            line-height: 1;
        }

        .nav-pill {
            color: rgba(37, 50, 41, .72);
            font-weight: 600;
            font-size: .93rem;
            border-radius: 999px;
            padding: .58rem .82rem !important;
            transition: .2s ease;
        }

        .nav-pill:hover {
            color: var(--green-900);
            background: rgba(46, 98, 73, .10);
            transform: translateY(-1px);
        }

        .nav-pill i {
            color: var(--green-700);
        }

        .page-header {
            padding-top: 2rem;
            padding-bottom: 1.35rem;
            animation: fadeUp .45s ease both;
        }

        .eyebrow {
            display: inline-flex;
            align-items: center;
            gap: .45rem;
            padding: .45rem .78rem;
            border-radius: 999px;
            color: var(--green-800);
            background: rgba(46, 98, 73, .10);
            border: 1px solid rgba(46, 98, 73, .13);
            font-size: .78rem;
            font-weight: 700;
            letter-spacing: .06em;
            text-transform: uppercase;
        }

        .page-title {
            margin: .75rem 0 0;
            color: var(--green-900);
            font-weight: 800;
            letter-spacing: -.045em;
        }

        .app-content {
            animation: fadeUp .55s ease both;
        }

        .surface {
            background: rgba(255, 250, 240, .82);
            border: 1px solid var(--border);
            border-radius: var(--radius-xl);
            box-shadow: var(--shadow);
            backdrop-filter: blur(12px);
        }

        .surface-flat {
            background: rgba(255, 250, 240, .72);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
        }

        .btn {
            border-radius: 999px;
            font-weight: 700;
            letter-spacing: -.01em;
            transition: .2s ease;
        }

        .btn:hover {
            transform: translateY(-2px);
        }

        .btn-primary {
            background: var(--green-800);
            border-color: var(--green-800);
            box-shadow: 0 14px 34px rgba(33, 71, 52, .20);
        }

        .btn-primary:hover {
            background: var(--green-900);
            border-color: var(--green-900);
        }

        .btn-outline-primary {
            color: var(--green-800);
            border-color: rgba(46, 98, 73, .28);
            background: rgba(255, 250, 240, .42);
        }

        .btn-outline-primary:hover {
            background: var(--green-800);
            border-color: var(--green-800);
            color: var(--paper-light);
        }

        .btn-outline-danger {
            color: var(--wine);
            border-color: rgba(122, 39, 53, .28);
        }

        .btn-outline-danger:hover,
        .btn-danger {
            background: var(--wine);
            border-color: var(--wine);
        }

        .card,
        .list-group-item,
        .form-control,
        .form-select,
        .alert,
        .table {
            border-color: var(--border) !important;
        }

        .card {
            border-radius: var(--radius-lg);
            background: rgba(255, 250, 240, .78);
        }

        .form-control,
        .form-select {
            border-radius: var(--radius-md);
            background-color: rgba(255, 250, 240, .74);
            padding: .72rem .9rem;
        }

        .form-control:focus,
        .form-select:focus {
            border-color: rgba(46, 98, 73, .55) !important;
            box-shadow: 0 0 0 .22rem rgba(46, 98, 73, .12);
        }

        .form-label {
            color: var(--green-800) !important;
            letter-spacing: .06em;
        }

        .table {
            overflow: hidden;
            border-radius: var(--radius-lg);
            background: rgba(255, 250, 240, .82);
        }

        .table-primary {
            --bs-table-bg: rgba(46, 98, 73, .12);
            --bs-table-color: var(--green-900);
            border-color: rgba(46, 98, 73, .16);
        }

        .table-hover tbody tr {
            transition: .18s ease;
        }

        .table-hover tbody tr:hover {
            --bs-table-hover-bg: rgba(198, 156, 74, .12);
        }

        .table-danger {
            --bs-table-bg: rgba(122, 39, 53, .10);
            --bs-table-color: var(--wine-dark);
        }

        .badge {
            font-weight: 700;
        }

        .text-primary {
            color: var(--green-800) !important;
        }

        .text-secondary {
            color: var(--muted) !important;
        }

        .bg-primary,
        .text-bg-primary {
            background-color: var(--green-800) !important;
        }

        .border-primary-subtle {
            border-color: rgba(46, 98, 73, .18) !important;
        }

        .border-danger-subtle {
            border-color: rgba(122, 39, 53, .20) !important;
        }

        .list-group-item {
            background: rgba(255, 250, 240, .58);
            transition: .18s ease;
        }

        .list-group-item:hover {
            background: rgba(242, 223, 181, .34);
            transform: translateX(4px);
        }

        .toast-notice {
            position: fixed;
            right: 1.25rem;
            bottom: 1.25rem;
            z-index: 1080;
            max-width: 340px;
            border-radius: 20px;
            border: 1px solid rgba(46, 98, 73, .16);
            background: rgba(255, 250, 240, .92);
            box-shadow: var(--shadow);
            backdrop-filter: blur(16px);
            animation: slideToast .55s ease both;
        }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(12px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes slideToast {
            from {
                opacity: 0;
                transform: translateY(14px) scale(.98);
            }

            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        @@media (max-width: 991px) {
            .navbar-nav {
                padding-top: 1rem;
                padding-bottom: .5rem;
            }

            .nav-pill {
                padding-left: 1rem !important;
            }
        }
    </style>
</head>

<body>
    <nav class="navbar navbar-expand-lg app-navbar">
        <div class="container navbar-inner">
            <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                <span class="brand-mark">
                    <i class="bi bi-book-half fs-4"></i>
                </span>

                <span class="d-flex flex-column">
                    <span class="fw-bold fs-5">Clube da Leitura</span>
                    <span class="brand-subtitle">acervo · reservas · empréstimos</span>
                </span>
            </a>

            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#menuPrincipal"
                    aria-controls="menuPrincipal" aria-expanded="false" aria-label="Alternar navegação">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="menuPrincipal">
                <div class="navbar-nav ms-auto gap-1">
                    <a class="nav-link nav-pill" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house-door me-1"></i>Início
                    </a>

                    <a class="nav-link nav-pill" asp-controller="Caixa" asp-action="Listar">
                        <i class="bi bi-archive me-1"></i>Caixas
                    </a>

                    <a class="nav-link nav-pill" asp-controller="Amigo" asp-action="Listar">
                        <i class="bi bi-people me-1"></i>Amigos
                    </a>

                    <a class="nav-link nav-pill" asp-controller="Revista" asp-action="Listar">
                        <i class="bi bi-journal-richtext me-1"></i>Revistas
                    </a>

                    <a class="nav-link nav-pill" asp-controller="Emprestimo" asp-action="Listar">
                        <i class="bi bi-arrow-left-right me-1"></i>Empréstimos
                    </a>

                    <a class="nav-link nav-pill" asp-controller="Reserva" asp-action="Listar">
                        <i class="bi bi-bookmark-check me-1"></i>Reservas
                    </a>

                    <a class="nav-link nav-pill" asp-controller="Multa" asp-action="Listar">
                        <i class="bi bi-receipt me-1"></i>Multas
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <header class="container page-header">
        <span class="eyebrow">
            <i class="bi bi-feather"></i>
            Sistema do clube
        </span>

        <h2 class="page-title">@ViewBag.Titulo</h2>
    </header>

    <main class="container pb-5 app-content">
        @RenderBody()
    </main>

    <div class="toast-notice d-none d-lg-block p-3">
        <div class="d-flex gap-3 align-items-start">
            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                 style="width: 38px; height: 38px; background: rgba(46, 98, 73, .12); color: var(--green-800);">
                <i class="bi bi-lightning-charge-fill"></i>
            </div>

            <div>
                <strong class="d-block mb-1">Fluxo inteligente</strong>
                <small class="text-secondary">
                    Reservas, empréstimos e multas são controlados pelas regras do sistema.
                </small>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
            crossorigin="anonymous"></script>
</body>

</html>
