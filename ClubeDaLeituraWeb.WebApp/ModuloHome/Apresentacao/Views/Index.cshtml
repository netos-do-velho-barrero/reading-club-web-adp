@{
    Layout = "_Layout";
    ViewBag.Titulo = "Página Inicial";
}

<div class="row align-items-start">
    <div class="col-lg-7">
        <h1 class="display-5 fw-semibold mb-3">Clube da Leitura</h1>

        <p class="lead text-secondary mb-4">
            Organize caixas, revistas, empréstimos e amigos em uma aplicação simples para acompanhar a rotina do clube.
        </p>

        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary rounded-pill px-4" asp-controller="Caixa" asp-action="Listar">
                Acessar Caixas
            </a>

            <a class="btn btn-primary rounded-pill px-4" asp-controller="Amigo" asp-action="Listar">
                Acessar Amigos
            </a>

            <a class="btn btn-primary rounded-pill px-4" asp-controller="Revista" asp-action="Listar">
                Acessar Revistas
            </a>

            <a class="btn btn-primary rounded-pill px-4" asp-controller="Emprestimo" asp-action="Listar">
                Acessar Empréstimos
            </a>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card border-primary-subtle shadow-sm">
            <div class="card-body p-4">
                <h3 class="h5 text-primary mb-3">Módulos disponíveis</h3>

                <div class="list-group">
                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                       asp-controller="Caixa" asp-action="Listar">
                        Controle de Caixas
                        <span class="badge text-bg-primary rounded-pill">Abrir</span>
                    </a>

                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                       asp-controller="Amigo" asp-action="Listar">
                        Controle de Amigos
                        <span class="badge text-bg-primary rounded-pill">Abrir</span>
                    </a>

                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                       asp-controller="Revista" asp-action="Listar">
                        Controle de Revistas
                        <span class="badge text-bg-primary rounded-pill">Abrir</span>
                    </a>

                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                       asp-controller="Emprestimo" asp-action="Listar">
                        Controle de Empréstimos
                        <span class="badge text-bg-primary rounded-pill">Abrir</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
