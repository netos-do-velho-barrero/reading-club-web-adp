@{
    Layout = "_Layout";
    ViewBag.Titulo = "Exclusão de Revista";
}

@model ExcluirRevistasViewModel;

<div class="card border-danger-subtle shadow-sm mx-auto p-4" style="max-width: 620px;">

    <h5 class="text-danger fw-semibold mb-3">Confirmar exclusão</h5>

    <p class="mb-4">
        Tem certeza que deseja excluir esta revista?
    </p>

    <div class="mb-3">
        <label class="form-label fw-semibold text-primary text-uppercase small">Título</label>
        <input value="@Model.Titulo" type="text" class="form-control" disabled>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold text-primary text-uppercase small">Número da Edição</label>
        <input value="@Model.NumeroEdicao" type="number" class="form-control" disabled>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold text-primary text-uppercase small">Ano de Publicação</label>
        <input value="@Model.AnoPublicacao" type="number" class="form-control" disabled>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold text-primary text-uppercase small">Caixa</label>
        <input value="@Model.NomeCaixa" type="text" class="form-control" disabled>
    </div>

    <form asp-action="Excluir" method="post">
        <input asp-for="Id" type="hidden">

        <div class="d-flex justify-content-end gap-2 mt-4">
            <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
            <button class="btn btn-danger rounded-pill px-4" type="submit">Excluir</button>
        </div>
    </form>
</div>
