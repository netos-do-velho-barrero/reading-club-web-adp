@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Revistas";
}

@model List<ListarRevistasViewModel>;

<a class="btn btn-outline-primary rounded-pill px-4 mb-3" asp-action="Cadastrar">Cadastrar Novo</a>

@if (Model.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-2 rounded-3" role="alert">
        Nenhuma revista cadastrada.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover table-bordered align-middle bg-white">
            <thead class="table-primary">
                <tr>
                    <th>ID</th>
                    <th>Título</th>
                    <th>Número da Edição</th>
                    <th>Ano de Publicação</th>
                    <th>Caixa</th>
                    <th>Status</th>
                    <th>Ações</th>
                </tr>
            </thead>

            <tbody>
                @foreach (ListarRevistasViewModel r in Model)
                {
                    <tr>
                        <td>@r.Id</td>
                        <td>@r.Titulo</td>
                        <td>@r.NumeroEdicao</td>
                        <td>@r.AnoPublicacao</td>
                        <td>@r.NomeCaixa</td>
                        <td>@r.Status</td>
                        <td>
                            <div class="d-flex gap-2">
                                <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Editar"
                                   asp-route-id="@r.Id">Editar</a>
                                <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Excluir"
                                   asp-route-id="@r.Id">Excluir</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
