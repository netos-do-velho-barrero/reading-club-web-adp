@{
    Layout = "_Layout";
    ViewBag.Titulo = "Devolução de Empréstimo";
}

@model DevolverEmprestimoViewModel;

<div class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;">

    <h5 class="text-primary fw-semibold mb-3">Confirmar devolução</h5>

    <p class="mb-4">
        Tem certeza que deseja registrar a devolução deste empréstimo?
    </p>

    <div class="mb-3">
        <label class="form-label fw-semibold text-primary text-uppercase small">Amigo</label>
        <input value="@Model.NomeAmigo" type="text" class="form-control" disabled>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold text-primary text-uppercase small">Revista</label>
        <input value="@Model.TituloRevista" type="text" class="form-control" disabled>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold text-primary text-uppercase small">Data de Empréstimo</label>
        <input value="@Model.Abertura.ToString("dd/MM/yyyy")" type="text" class="form-control" disabled>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold text-primary text-uppercase small">Devolução Prevista</label>
        <input value="@Model.ConclusaoPrevista.ToString("dd/MM/yyyy")" type="text" class="form-control" disabled>
    </div>

    <form asp-action="Devolver" method="post">
        <input asp-for="Id" type="hidden">

        <div class="d-flex justify-content-end gap-2 mt-4">
            <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
            <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar Devolução</button>
        </div>
    </form>
</div>
