@{
    Layout = "_Layout";
    ViewBag.Titulo = "Quitar Multa";
}

@model QuitarMultaViewModel;

<div class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;">

    <h5 class="text-primary fw-semibold mb-3">Confirmar pagamento</h5>

    <p class="mb-4">
        Tem certeza que deseja quitar esta multa?
    </p>

    <div class="mb-3">
        <label class="form-label fw-semibold text-primary text-uppercase small">Amigo</label>
        <input value="@Model.NomeAmigo" type="text" class="form-control" disabled>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold text-primary text-uppercase small">Revista</label>
        <input value="@Model.TituloRevista" type="text" class="form-control" disabled>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold text-primary text-uppercase small">Dias de Atraso</label>
        <input value="@Model.DiasAtraso" type="number" class="form-control" disabled>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold text-primary text-uppercase small">Valor</label>
        <input value="@Model.Valor.ToString("C")" type="text" class="form-control" disabled>
    </div>

    <form asp-action="Quitar" method="post">
        <input asp-for="Id" type="hidden">

        <div class="d-flex justify-content-end gap-2 mt-4">
            <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
            <button class="btn btn-primary rounded-pill px-4" type="submit">Quitar</button>
        </div>
    </form>
</div>
