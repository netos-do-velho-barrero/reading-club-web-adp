@{
    Layout = "_Layout";
    ViewBag.Titulo = "Multas por Amigo";
}

@model List<ListarMultasViewModel>;

<form class="card border-primary-subtle shadow-sm mx-auto p-4 mb-4" style="max-width: 620px;"
      asp-action="FiltrarPorAmigo" method="get">
    <div class="mb-3">
        <label class="form-label fw-semibold text-primary text-uppercase small">Amigo</label>

        <select name="amigoId" class="form-select">
            <option value="">Selecione um amigo</option>

            @foreach (Amigo amigo in ViewBag.Amigos)
            {
                <option value="@amigo.Id">@amigo.Nome</option>
            }
        </select>
    </div>

    <div class="d-flex justify-content-end gap-2">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
        <button class="btn btn-primary rounded-pill px-4" type="submit">Buscar</button>
    </div>
</form>

@if (Model.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-2 rounded-3" role="alert">
        Nenhuma multa encontrada para este amigo.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover table-bordered align-middle bg-white">
            <thead class="table-primary">
                <tr>
                    <th>ID</th>
                    <th>Amigo</th>
                    <th>Revista</th>
                    <th>Data do Empréstimo</th>
                    <th>Devolução Prevista</th>
                    <th>Dias de Atraso</th>
                    <th>Valor</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody>
                @foreach (ListarMultasViewModel m in Model)
                {
                    string classeLinha = m.Status == "Pendente" ? "table-danger" : string.Empty;

                    <tr class="@classeLinha">
                        <td>@m.Id</td>
                        <td>@m.NomeAmigo</td>
                        <td>@m.TituloRevista</td>
                        <td>@m.DataEmprestimo.ToString("dd/MM/yyyy")</td>
                        <td>@m.DataDevolucaoPrevista.ToString("dd/MM/yyyy")</td>
                        <td>@m.DiasAtraso</td>
                        <td>@m.Valor.ToString("C")</td>
                        <td>@m.Status</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
