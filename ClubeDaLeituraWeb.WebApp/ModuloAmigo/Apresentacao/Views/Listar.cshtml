@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Amigos";
}

@model List<ListarAmigosViewModel>;


<a class="btn btn-outline-primary rounded-pill px-4 mb-3" asp-action="Cadastrar">Cadastrar Novo</a>

@if (Model.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-2 rounded-3" role="alert">
        Nenhuma caixa cadastrada.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover table-bordered align-middle bg-white">
            <thead class="table-primary">
                <tr>
                    <th>ID</th>
                    <th>Nome</th>
                    <th>NomeResponsavel</th>
                    <th>Telefone</th>
                    <th>Ações</th>
                </tr>
            </thead>

            <tbody>
                @foreach (ListarAmigosViewModel a in Model)
                {
                    <tr>
                        <td>@a.Id</td>
                        <td>@a.Nome</td>
                        <td>@a.NomeResponsavel</td>
                        <td>@a.Telefone</td>
                        <td>
                            <div class="d-flex gap-2">
                                <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Editar"
                                   asp-route-id="@a.Id">Editar</a>
                                <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Excluir"
                                   asp-route-id="@a.Id">Excluir</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
